# Copia este archivo a .env.local (desarrollo) y configura las mismas
# variables en Vercel → Project Settings → Environment Variables (producción).
# Ver SETUP.md para cómo obtener cada valor.

# Auth.js (NextAuth v5)
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# OAuth Client de Google (Google Cloud Console)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Web App de Google Apps Script (backend sobre el Google Sheet)
APPS_SCRIPT_URL=
APPS_SCRIPT_TOKEN=
